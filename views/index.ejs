<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>

    <style>
          
             tr,
             th,
             td{
                  border: 1px solid black;
               }
    </style>
</head>
<body>
    

        <table>
               
               <tr>
                   <th> name </th>
                   <th> aadhar_number </th>
                   <th> email </th>
                </tr>

                     <% for(user of data){%> 
                       
                        <tr>
                           <td> <%= user.name %> </td>
                           <td> <%= user.aadhar_number %> </td>
                           <td> <%= user.email %> </td>
                           <td><button> edit </button></td>
                        </tr>
                     <%}%> 
        </table>


</body>
</html>